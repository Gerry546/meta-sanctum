{
    "description": "Sanctum - 'core image minimal' configuration",
    "bitbake-setup": {
        "configurations": [
            {
                "bb-layers": [
                    "meta-sanctum/meta-sanctum",
                    "meta-openembedded/meta-oe",
                    "openembedded-core/meta"
                ],
                "configurations": [
                    {
                        "name": "homeassistant",
                        "description": "HomeAssistant Build Configuration",
                        "bb-layers": [
                            "meta-homeassistant",
                            "meta-yocto/meta-poky",
                            "meta-openembedded/meta-filesystems",
                            "meta-openembedded/meta-multimedia",
                            "meta-openembedded/meta-networking",
                            "meta-openembedded/meta-python",
                            "meta-python-ai",
                            "meta-sca",
                            "meta-virtualization"
                        ],
                        "oe-fragments": [
                            "meta-sanctum/infrastructure/commercial-license",
                            "meta-sanctum/testing/qemu-testing",
                            "core/yocto/root-login-with-empty-password",
                            "distro/homeassistant"
                        ],
                        "oe-fragments-one-of": {
                            "machine": {
                                "description": "Target machines",
                                "options": [
                                    { "name": "machine/qemux86-64", "description": "QEMU x86-64" },
                                    { "name": "machine/qemux86-64n", "description": "QEMU x86-64, tailored for Sanctum projects" },
                                    { "name": "machine/qemuarm64", "description": "QEMU ARM64" },
                                    { "name": "machine/qemuarm64-a72", "description": "QEMU ARM64 with A72 core tuning" },
                                    { "name": "machine/qemuriscv64", "description": "QEMU RISC-V 64" }
                                ]
                            }
                        },
                        "setup-dir-name": "build/build-homeassistant"
                    },
                    {
                        "name": "openembedded-test",
                        "description": "Openembedded testing environment",
                        "bb-layers": [
                        ],
                        "oe-fragments-one-of": {
                            "machine": {
                                "description": "Target machines",
                                "options": [
                                    { "name": "machine/qemux86-64", "description": "QEMU x86-64" },
                                    { "name": "machine/qemux86-64n", "description": "QEMU x86-64, tailored for Sanctum projects" },
                                    { "name": "machine/qemuarm64", "description": "QEMU ARM64" },
                                    { "name": "machine/qemuarm64-a72", "description": "QEMU ARM64 with A72 core tuning" },
                                    { "name": "machine/qemuriscv64", "description": "QEMU RISC-V 64" }
                                ]
                            }
                        },
                        "oe-fragments": [
                            "meta-sanctum/testing/qemu-testing",
                            "distro/sanctum"
                        ],
                        "setup-dir-name": "build/build-openembedded-test"
                    },
                    {
                        "name": "sanctum",
                        "description": "Standard Sanctum Build Configuration",
                        "setup-dir-name": "build/build-sanctum",
                        "bb-layers": [
                            "meta-rauc"
                        ],
                        "oe-fragments-one-of": {
                            "machine": {
                                "description": "Target machines",
                                "options": [
                                    { "name": "machine/qemux86-64", "description": "QEMU x86-64" },
                                    { "name": "machine/qemux86-64n", "description": "QEMU x86-64, tailored for Sanctum projects" },
                                    { "name": "machine/qemuarm64", "description": "QEMU ARM64" },
                                    { "name": "machine/qemuarm64-a72", "description": "QEMU ARM64 with A72 core tuning" },
                                    { "name": "machine/qemuriscv64", "description": "QEMU RISC-V 64" }
                                ]
                            }
                        },
                        "oe-fragments": [
                            "core/yocto/root-login-with-empty-password",
                            "meta-sanctum/testing/rauc-qemu-testing",
                            "distro/sanctum"
                        ]
                    },
                    {
                        "name": "gnome-image",
                        "description": "GNOME Image Build Configuration",
                        "bb-layers": [
                            "meta-openembedded/meta-gnome",
                            "meta-openembedded/meta-python",
                            "meta-openembedded/meta-networking",
                            "meta-openembedded/meta-multimedia"
                        ],
                        "oe-fragments-one-of": {
                            "machine": {
                                "description": "Target machines",
                                "options": [
                                    { "name": "machine/qemux86-64", "description": "QEMU x86-64" },
                                    { "name": "machine/qemux86-64n", "description": "QEMU x86-64, tailored for Sanctum projects" },
                                    { "name": "machine/qemuarm64", "description": "QEMU ARM64" },
                                    { "name": "machine/qemuarm64-a72", "description": "QEMU ARM64 with A72 core tuning" },
                                    { "name": "machine/qemuriscv64", "description": "QEMU RISC-V 64" }
                                ]
                            }
                        },
                        "oe-fragments": [
                            "meta-sanctum/graphical/gnome-dependencies",
                            "distro/sanctum"
                        ],
                        "setup-dir-name": "build/build-gnome-image"
                    },
                    {
                        "name": "raspberrypi",
                        "description": "Build configuration for a Raspberry Pi device",
                        "bb-layers": [
                            "meta-raspberrypi",
                            "meta-rauc"
                        ],
                        "oe-fragments-one-of": {
                            "machine": {
                                "description": "Target machines",
                                "options": [
                                    { "name": "machine/reterminal", "description": "ReTerminal" },
                                    { "name": "machine/raspberrypi2-64", "description": "Raspberry Pi 2 (64-bit)" }
                                ]
                            }
                        },
                        "oe-fragments": [
                             "meta-sanctum/infrastructure/commercial-license",
                             "core/yocto/root-login-with-empty-password",
                             "distro/sanctum"
                        ],
                        "setup-dir-name": "build/build-raspberrypi"
                    }
                ]
            }
        ]
    },
